{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: API (local, DB in Docker)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DATABASE_URL": "postgresql://mjc:mjc@127.0.0.1:5432/mjcbot",
        "DATA_DIR": "${workspaceFolder}/data"
      },
      "jinja": true,
      "justMyCode": true
    }
  ]
}
