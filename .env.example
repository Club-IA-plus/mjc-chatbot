POSTGRES_USER=mjc
POSTGRES_PASSWORD=mjc
POSTGRES_DB=mjcbot
DATABASE_URL=postgresql://mjc:mjc@db:5432/mjcbot
# Used at `next build` for rewrites (Docker: http://backend:8000). Local `next dev`: http://127.0.0.1:8000
BACKEND_INTERNAL_URL=http://backend:8000
MISTRAL_API_KEY=
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
# Must match DB column `vector(N)` and Mistral embedding length (default 1024 for mistral-embed)
MISTRAL_EMBED_DIM=1024
RAG_TOP_K=5
